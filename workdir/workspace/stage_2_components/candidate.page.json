{
  "root": "demo-root",
  "elements": {
    "demo-root": {
      "type": "Flex",
      "props": {
        "direction": "vertical",
        "gap": 12
      },
      "children": [
        "demo-header",
        "demo-body"
      ]
    },
    "demo-header": {
      "type": "Card",
      "props": {
        "title": "页面标题：差旅报销申请"
      },
      "children": [
        "demo-title"
      ]
    },
    "demo-title": {
      "type": "TypographyText",
      "props": {
        "text": "阶段一占位文本"
      },
      "children": []
    },
    "demo-body": {
      "type": "Card",
      "props": {
        "title": "内容区域占位"
      },
      "children": [
        "demo-toolbar",
        "demo-table"
      ]
    },
    "demo-toolbar": {
      "type": "Space",
      "props": {
        "direction": "horizontal",
        "gap": 8
      },
      "children": [
        "demo-search-input",
        "demo-search-btn"
      ]
    },
    "demo-search-input": {
      "type": "Input",
      "props": {
        "placeholder": "请输入关键词"
      },
      "children": []
    },
    "demo-search-btn": {
      "type": "Button",
      "props": {
        "label": "查询",
        "variant": "primary"
      },
      "children": []
    },
    "demo-table": {
      "type": "Table",
      "props": {
        "columns": [
          {
            "title": "名称",
            "dataIndex": "name"
          },
          {
            "title": "状态",
            "dataIndex": "status"
          }
        ]
      },
      "children": []
    }
  }
}
