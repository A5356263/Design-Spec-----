{
  "root": "page_root",
  "elements": {
    "page_root": {
      "type": "Flex",
      "props": {
        "direction": "vertical",
        "gap": 24,
        "width": "100%"
      },
      "children": ["top_section", "main_section", "bottom_section"]
    },
    "top_section": {
      "type": "Card",
      "props": {
        "title": "顶部标题与操作区",
        "padding": 24,
        "gap": 16,
        "width": "100%"
      },
      "children": ["top_layout"]
    },
    "top_layout": {
      "type": "Flex",
      "props": {
        "justify": "space-between",
        "align": "center",
        "gap": 16,
        "width": "100%"
      },
      "children": ["top_title_group", "top_action_group"]
    },
    "top_title_group": {
      "type": "Space",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "start"
      },
      "children": ["page_title", "page_desc"]
    },
    "page_title": {
      "type": "TypographyText",
      "props": {
        "text": "差旅报销申请",
        "level": 2,
        "emphasis": "strong"
      },
      "children": []
    },
    "page_desc": {
      "type": "TypographyText",
      "props": {
        "text": "用于创建并提交本次差旅报销",
        "level": 4
      },
      "children": []
    },
    "top_action_group": {
      "type": "Space",
      "props": {
        "direction": "horizontal",
        "gap": 12,
        "align": "center"
      },
      "children": ["status_tag", "save_draft_button", "submit_button_top"]
    },
    "status_tag": {
      "type": "Tag",
      "props": {
        "label": "状态待补充",
        "tone": "info",
        "size": "middle"
      },
      "children": []
    },
    "save_draft_button": {
      "type": "Button",
      "props": {
        "label": "保存草稿",
        "variant": "default",
        "size": "middle"
      },
      "children": []
    },
    "submit_button_top": {
      "type": "Button",
      "props": {
        "label": "提交审批",
        "variant": "primary",
        "size": "middle"
      },
      "children": []
    },
    "main_section": {
      "type": "Flex",
      "props": {
        "direction": "horizontal",
        "gap": 24,
        "align": "start",
        "width": "100%"
      },
      "children": ["left_primary_area", "right_assist_area"]
    },
    "left_primary_area": {
      "type": "Flex",
      "props": {
        "direction": "vertical",
        "gap": 16,
        "width": "70%"
      },
      "children": ["basic_info_module", "expense_detail_module", "extra_note_module"]
    },
    "basic_info_module": {
      "type": "Card",
      "props": {
        "title": "基础信息",
        "padding": 24,
        "gap": 12,
        "width": "100%"
      },
      "children": ["basic_info_form"]
    },
    "basic_info_form": {
      "type": "Form",
      "props": {
        "layout": "vertical",
        "disabled": false
      },
      "children": [
        "field_reimburse_no",
        "field_applicant",
        "field_department",
        "field_trip_reason",
        "field_start_date",
        "field_end_date"
      ]
    },
    "field_reimburse_no": {
      "type": "Input",
      "props": {
        "placeholder": "报销单编号",
        "disabled": true
      },
      "children": []
    },
    "field_applicant": {
      "type": "Input",
      "props": {
        "placeholder": "申请人"
      },
      "children": []
    },
    "field_department": {
      "type": "Select",
      "props": {
        "placeholder": "所属部门"
      },
      "children": []
    },
    "field_trip_reason": {
      "type": "Input",
      "props": {
        "placeholder": "出差事由"
      },
      "children": []
    },
    "field_start_date": {
      "type": "Input",
      "props": {
        "placeholder": "出差开始日期"
      },
      "children": []
    },
    "field_end_date": {
      "type": "Input",
      "props": {
        "placeholder": "出差结束日期"
      },
      "children": []
    },
    "expense_detail_module": {
      "type": "Card",
      "props": {
        "title": "费用明细",
        "padding": 24,
        "gap": 12,
        "width": "100%"
      },
      "children": ["expense_table"]
    },
    "expense_table": {
      "type": "Table",
      "props": {
        "columns": ["日期", "费用类型", "金额", "说明"],
        "size": "middle",
        "bordered": true,
        "width": "100%"
      },
      "children": []
    },
    "extra_note_module": {
      "type": "Card",
      "props": {
        "title": "补充说明",
        "padding": 24,
        "gap": 12,
        "width": "100%"
      },
      "children": ["extra_note_input"]
    },
    "extra_note_input": {
      "type": "Input",
      "props": {
        "placeholder": "补充说明"
      },
      "children": []
    },
    "right_assist_area": {
      "type": "Flex",
      "props": {
        "direction": "vertical",
        "gap": 16,
        "width": "30%"
      },
      "children": ["rule_hint_module", "summary_info_module"]
    },
    "rule_hint_module": {
      "type": "Card",
      "props": {
        "title": "报销规则提示",
        "padding": 24,
        "gap": 12,
        "width": "100%"
      },
      "children": ["rule_hint_alert"]
    },
    "rule_hint_alert": {
      "type": "Alert",
      "props": {
        "message": "报销规则提示",
        "description": "阶段三补充具体规则文案",
        "tone": "info",
        "showGlyph": true
      },
      "children": []
    },
    "summary_info_module": {
      "type": "Card",
      "props": {
        "title": "汇总信息",
        "padding": 24,
        "gap": 12,
        "width": "100%"
      },
      "children": ["summary_info_group"]
    },
    "summary_info_group": {
      "type": "Space",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "start"
      },
      "children": ["summary_total", "summary_count", "summary_status"]
    },
    "summary_total": {
      "type": "TypographyText",
      "props": {
        "text": "费用合计：待补充",
        "level": 4
      },
      "children": []
    },
    "summary_count": {
      "type": "TypographyText",
      "props": {
        "text": "明细条数：待补充",
        "level": 4
      },
      "children": []
    },
    "summary_status": {
      "type": "TypographyText",
      "props": {
        "text": "当前状态：待补充",
        "level": 4
      },
      "children": []
    },
    "bottom_section": {
      "type": "Card",
      "props": {
        "title": "底部提交操作区",
        "padding": 24,
        "gap": 12,
        "width": "100%"
      },
      "children": ["bottom_layout"]
    },
    "bottom_layout": {
      "type": "Flex",
      "props": {
        "justify": "flex-end",
        "gap": 12,
        "width": "100%"
      },
      "children": ["cancel_button", "submit_button_bottom"]
    },
    "cancel_button": {
      "type": "Button",
      "props": {
        "label": "取消",
        "variant": "default",
        "size": "middle"
      },
      "children": []
    },
    "submit_button_bottom": {
      "type": "Button",
      "props": {
        "label": "提交审批",
        "variant": "primary",
        "size": "middle"
      },
      "children": []
    }
  }
}
